#!/usr/bin/env bash
set -u

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CMD_NAME="$(basename "$0")"

BRAIN_ROOT="${BRAIN_ROOT:-${SYNAPSE_HOME:-$HOME/Synapse}}"
BRAIN_VAULT="${BRAIN_VAULT:-$BRAIN_ROOT/vault}"
BRAIN_BOOT="${BRAIN_BOOT:-$BRAIN_VAULT/AGENTS.md}"
BRAIN_WORKFLOW="${BRAIN_WORKFLOW:-$BRAIN_VAULT/_meta/workflow.md}"
BRAIN_GLOBAL_AGENTS="${BRAIN_GLOBAL_AGENTS:-$HOME/AGENTS.md}"
BRAIN_SKILLS_DIR="${BRAIN_SKILLS_DIR:-$BRAIN_VAULT/skills}"

vault_hash() {
  if [[ -f "$BRAIN_VAULT/index.md" ]]; then
    cksum "$BRAIN_VAULT/index.md" 2>/dev/null | awk '{print $1}'
  else
    printf 'none'
  fi
}

BRAIN_SESSION_ID="${BRAIN_SESSION_ID:-$(date +%Y%m%d-%H%M%S)-$$}"
BRAIN_VAULT_HASH="${BRAIN_VAULT_HASH:-$(vault_hash)}"

export BRAIN_ROOT BRAIN_VAULT BRAIN_BOOT BRAIN_WORKFLOW BRAIN_GLOBAL_AGENTS
export BRAIN_SKILLS_DIR BRAIN_SESSION_ID BRAIN_VAULT_HASH
export SYNAPSE_HOME="${SYNAPSE_HOME:-$BRAIN_ROOT}"
export OBSIDIAN_VAULT_PATH="${OBSIDIAN_VAULT_PATH:-$BRAIN_VAULT}"
export OBSIDIAN_WIKI_REPO="${OBSIDIAN_WIKI_REPO:-$BRAIN_ROOT}"
export OBSIDIAN_LINK_FORMAT="${OBSIDIAN_LINK_FORMAT:-wikilink}"

usage() {
  cat <<EOF
$CMD_NAME — Synapse: persistent memory bootstrap for agentic CLIs

Usage:
  $CMD_NAME <cli> [args...]   run an agent CLI with the vault environment loaded
  $CMD_NAME status           vault active? session id, staleness
  $CMD_NAME check            read-only quality gate: validate + dedup
  $CMD_NAME skill <cmd>      skill scorecards: list | use | rate | show
  $CMD_NAME doctor           verify boot files exist
  $CMD_NAME which <cmd>      resolve command (and if Synapse wraps it)
  $CMD_NAME reinit           idempotently (re)write the shell-rc block
  $CMD_NAME env              print environment

Examples:
  $CMD_NAME codex
  $CMD_NAME claude
  $CMD_NAME opencode

Legacy: \`brain\` is a symlink to \`synapse\` when installed via install.sh.
EOF
}

doctor() {
  local rc=0 path
  for path in "$BRAIN_BOOT" "$BRAIN_VAULT/index.md" "$BRAIN_VAULT/_meta/workflow.md" "$BRAIN_GLOBAL_AGENTS"; do
    if [[ -f "$path" ]]; then
      printf 'ok   %s\n' "$path"
    else
      printf 'miss %s\n' "$path"
      rc=1
    fi
  done
  return "$rc"
}

status() {
  if [[ "${BRAIN_LOADED:-0}" == "1" ]]; then
    printf 'synapse: ACTIVE in this environment\n'
  else
    printf 'synapse: NOT active — start via "%s <cli>" or a shell alias\n' "$CMD_NAME"
  fi
  printf 'vault:    %s\n' "$BRAIN_VAULT"
  printf 'skills:   %s\n' "$BRAIN_SKILLS_DIR"
  printf 'session:  %s\n' "$BRAIN_SESSION_ID"
  local now; now="$(vault_hash)"
  if [[ "${BRAIN_LOADED:-0}" == "1" && "$now" != "$BRAIN_VAULT_HASH" ]]; then
    printf 'hash:     %s  (STALE — vault changed since load; now %s)\n' "$BRAIN_VAULT_HASH" "$now"
  else
    printf 'hash:     %s\n' "$now"
  fi
  doctor
}

strip_rc_block() {
  local rc="$1" tmp
  tmp="$(mktemp)"
  awk '
    /# >>> Synapse >>>/ { skip=1 }
    skip && /# <<< Synapse <<</ { skip=0; next }
    /# >>> Agent Brain Runtime >>>/ { skip=1 }
    skip && /# <<< Agent Brain Runtime <<</ { skip=0; next }
    !skip { print }
  ' "$rc" > "$tmp" && mv "$tmp" "$rc"
}

reinit() {
  local prefix="$SELF_DIR" rc default_rc
  case "${SHELL:-}" in
    *bash) default_rc="$HOME/.bashrc" ;;
    *)     default_rc="$HOME/.zshrc" ;;
  esac
  rc="${SHELL_RC:-$default_rc}"

  if [[ -f "$rc" ]]; then
    strip_rc_block "$rc"
  fi

  cat >> "$rc" <<EOF

# >>> Synapse >>>
export SYNAPSE_HOME="$BRAIN_ROOT"
export BRAIN_ROOT="$BRAIN_ROOT"
export BRAIN_VAULT="$BRAIN_VAULT"
export BRAIN_BOOT="\$BRAIN_VAULT/AGENTS.md"
export BRAIN_WORKFLOW="\$BRAIN_VAULT/_meta/workflow.md"
export BRAIN_SKILLS_DIR="\$BRAIN_VAULT/skills"
export OBSIDIAN_VAULT_PATH="\${OBSIDIAN_VAULT_PATH:-\$BRAIN_VAULT}"
export OBSIDIAN_WIKI_REPO="\${OBSIDIAN_WIKI_REPO:-\$BRAIN_ROOT}"
export OBSIDIAN_LINK_FORMAT="\${OBSIDIAN_LINK_FORMAT:-wikilink}"
case ":\$PATH:" in
  *":$prefix:"*) ;;
  *) export PATH="$prefix:\$PATH" ;;
esac
alias codex='synapse codex'
alias opencode='synapse opencode'
alias claude='synapse claude'
alias gemini='synapse gemini'
# <<< Synapse <<<
EOF
  printf 'synapse: rewrote Synapse block in %s\n' "$rc"
  printf 'synapse: open a new terminal (or source it) to apply.\n'
}

check() {
  local v="$BRAIN_VAULT/_meta/validate.py" d="$BRAIN_VAULT/_meta/dedup.py" rc=0
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'synapse: python3 not found; cannot run check\n' >&2
    return 2
  fi
  if [[ -f "$v" ]]; then
    printf '== validate ==\n'
    python3 "$v" || rc=$?
  else
    printf 'synapse: no validate.py at %s\n' "$v" >&2
    rc=1
  fi
  if [[ -f "$d" ]]; then
    printf '\n== dedup (candidates) ==\n'
    python3 "$d" || true
  fi
  return "$rc"
}

which_cmd() {
  local c="${1:-}" p
  if [[ -z "$c" ]]; then
    printf 'usage: %s which <cmd>\n' "$CMD_NAME" >&2
    return 2
  fi
  p="$(command -v -- "$c" 2>/dev/null)" || { printf 'synapse: command not found: %s\n' "$c" >&2; return 127; }
  printf 'command:  %s\n' "$c"
  printf 'resolves: %s\n' "$p"
  if grep -qsE "$SELF_DIR/(synapse|brain)" "$p" 2>/dev/null; then
    printf 'type:     synapse wrapper -> %s\n' "$SELF_DIR"
  else
    printf 'type:     direct binary (not wrapped by synapse)\n'
  fi
  if [[ -e "$SELF_DIR/.synapse-real/$c" ]]; then
    printf 'real:     %s\n' "$(readlink "$SELF_DIR/.synapse-real/$c" 2>/dev/null || echo "$SELF_DIR/.synapse-real/$c")"
  fi
}

case "${1:-}" in
  ""|-h|--help)
    usage
    exit 0
    ;;
  status)
    status
    exit 0
    ;;
  check)
    check
    exit $?
    ;;
  skill)
    shift
    s="$BRAIN_VAULT/_meta/skill.py"
    if [[ ! -f "$s" ]]; then
      printf 'synapse: skill engine not found at %s\n' "$s" >&2
      exit 2
    fi
    if ! command -v python3 >/dev/null 2>&1; then
      printf 'synapse: python3 not found; cannot run skill\n' >&2
      exit 2
    fi
    BRAIN_SKILLS_DIR="$BRAIN_SKILLS_DIR" exec python3 "$s" "$@"
    ;;
  reinit)
    reinit
    exit 0
    ;;
  doctor)
    doctor
    exit $?
    ;;
  which)
    which_cmd "${2:-}"
    exit $?
    ;;
  env)
    printf 'SYNAPSE_HOME=%s\n' "$SYNAPSE_HOME"
    printf 'BRAIN_ROOT=%s\n' "$BRAIN_ROOT"
    printf 'BRAIN_VAULT=%s\n' "$BRAIN_VAULT"
    printf 'BRAIN_BOOT=%s\n' "$BRAIN_BOOT"
    printf 'BRAIN_WORKFLOW=%s\n' "$BRAIN_WORKFLOW"
    printf 'BRAIN_GLOBAL_AGENTS=%s\n' "$BRAIN_GLOBAL_AGENTS"
    printf 'BRAIN_SKILLS_DIR=%s\n' "$BRAIN_SKILLS_DIR"
    printf 'BRAIN_SESSION_ID=%s\n' "$BRAIN_SESSION_ID"
    printf 'BRAIN_VAULT_HASH=%s\n' "$BRAIN_VAULT_HASH"
    printf 'OBSIDIAN_VAULT_PATH=%s\n' "$OBSIDIAN_VAULT_PATH"
    printf 'OBSIDIAN_WIKI_REPO=%s\n' "$OBSIDIAN_WIKI_REPO"
    printf 'OBSIDIAN_LINK_FORMAT=%s\n' "$OBSIDIAN_LINK_FORMAT"
    exit 0
    ;;
esac

cmd="$1"
shift

if ! command -v -- "$cmd" >/dev/null 2>&1; then
  printf 'synapse: command not found: %s\n' "$cmd" >&2
  exit 127
fi

if [[ "${BRAIN_ACTIVE:-0}" != "1" && "${BRAIN_QUIET:-0}" != "1" ]]; then
  printf 'synapse[vault]: %s (session: %s)\n' "$BRAIN_VAULT" "$BRAIN_SESSION_ID" >&2
fi

export BRAIN_ACTIVE=1
export BRAIN_LOADED=1

exec "$cmd" "$@"
