#!/usr/bin/env bash
set -u

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CMD_NAME="$(basename "$0")"

# Capture an explicit BRAIN_VAULT override (pins the vault, bypasses the switcher).
ENV_BRAIN_VAULT="${BRAIN_VAULT:-}"
BRAIN_ROOT="${BRAIN_ROOT:-${SYNAPSE_HOME:-$HOME/Synapse}}"
VAULTS_DIR="$BRAIN_ROOT/vaults"
ACTIVE_VAULT_FILE="$BRAIN_ROOT/.active-vault"

# Resolve the active vault: explicit env override > named active vault > default.
resolve_vault() {
  if [[ -n "$ENV_BRAIN_VAULT" ]]; then printf '%s' "$ENV_BRAIN_VAULT"; return; fi
  if [[ -f "$ACTIVE_VAULT_FILE" ]]; then
    local n; n="$(tr -d '[:space:]' < "$ACTIVE_VAULT_FILE" 2>/dev/null)"
    if [[ -n "$n" && -d "$VAULTS_DIR/$n" ]]; then printf '%s' "$VAULTS_DIR/$n"; return; fi
  fi
  printf '%s' "$BRAIN_ROOT/vault"
}

BRAIN_VAULT="$(resolve_vault)"
BRAIN_BOOT="${BRAIN_BOOT:-$BRAIN_VAULT/AGENTS.md}"
BRAIN_WORKFLOW="${BRAIN_WORKFLOW:-$BRAIN_VAULT/_meta/workflow.md}"
BRAIN_GLOBAL_AGENTS="${BRAIN_GLOBAL_AGENTS:-$HOME/AGENTS.md}"
BRAIN_SKILLS_DIR="${BRAIN_SKILLS_DIR:-$BRAIN_VAULT/skills}"

vault_hash() {
  if [[ -f "$BRAIN_VAULT/index.md" ]]; then
    # Use sha256sum (Linux), shasum (macOS), or md5sum as fallback
    if command -v sha256sum >/dev/null 2>&1; then
      sha256sum "$BRAIN_VAULT/index.md" 2>/dev/null | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
      shasum -a 256 "$BRAIN_VAULT/index.md" 2>/dev/null | awk '{print $1}'
    elif command -v md5sum >/dev/null 2>&1; then
      md5sum "$BRAIN_VAULT/index.md" 2>/dev/null | awk '{print $1}'
    else
      # Fallback to cksum if nothing else is available
      cksum "$BRAIN_VAULT/index.md" 2>/dev/null | awk '{print $1}'
    fi
  else
    printf 'none'
  fi
}

BRAIN_SESSION_ID="${BRAIN_SESSION_ID:-$(date +%Y%m%d-%H%M%S)-$$}"
BRAIN_VAULT_HASH="${BRAIN_VAULT_HASH:-$(vault_hash)}"

export BRAIN_ROOT BRAIN_VAULT BRAIN_BOOT BRAIN_WORKFLOW BRAIN_GLOBAL_AGENTS
export BRAIN_SKILLS_DIR BRAIN_SESSION_ID BRAIN_VAULT_HASH
export SYNAPSE_HOME="${SYNAPSE_HOME:-$BRAIN_ROOT}"
export OBSIDIAN_VAULT_PATH="${OBSIDIAN_VAULT_PATH:-$BRAIN_VAULT}"
export OBSIDIAN_WIKI_REPO="${OBSIDIAN_WIKI_REPO:-$BRAIN_ROOT}"
export OBSIDIAN_LINK_FORMAT="${OBSIDIAN_LINK_FORMAT:-wikilink}"

usage() {
  cat <<EOF
$CMD_NAME — Synapse: persistent memory bootstrap for agentic CLIs

Synapse is an LLM Wiki (Karpathy's pattern): immutable raw/ sources, an LLM-owned
wiki of interlinked Markdown, and a schema (AGENTS.md) the agent follows to maintain it.

Usage:
  $CMD_NAME <cli> [args...]   run an agent CLI with the vault environment loaded
  $CMD_NAME vault [name]     list vaults, or switch to / create vault <name>
  $CMD_NAME setup <target>   install agent context file (claude-code|codex|cursor|gemini|opencode)
  $CMD_NAME hooks [install]  wire the continuous-loop hooks into ~/.claude/settings.json ('print' to preview)
  $CMD_NAME status           vault active? session id, staleness

  Wiki operations (Karpathy: ingest -> query -> lint):
  $CMD_NAME ingest <src>     record a source under raw/, create a linked sources/ page, log it
  $CMD_NAME query <query>    ranked retrieval (lexical, or semantic via the built index)
  $CMD_NAME file <cat> <ttl> file knowledge back as a wiki page (index + log) — compounds query
  $CMD_NAME lint [--strict]  health-check the wiki: validate + dedup + skill deps (= check)
  $CMD_NAME metrics          loop metrics: size, growth, activity, retrieval, stall signal

  $CMD_NAME search [opts]    filter notes by query, tag, or title (grep-based lookup)
  $CMD_NAME digest           (re)write _meta/digest.md — a compact map of the vault
  $CMD_NAME index [--backend bm25|tfidf|embeddings|hybrid]   build optional retrieval index (default: bm25)
  $CMD_NAME skill <cmd>      skill scorecards: list | use | rate | show | suggest | deps
  $CMD_NAME check [--strict] alias for lint
  $CMD_NAME doctor           verify boot files exist
  $CMD_NAME which <cmd>      resolve command (and if Synapse wraps it)
  $CMD_NAME reinit           idempotently (re)write the shell-rc block
  $CMD_NAME env              print environment

Search options:
  --tag <tag>       filter by tag
  --title <title>   filter by title
  --exact           exact string match (no regex)

Examples:
  $CMD_NAME codex
  $CMD_NAME claude
  $CMD_NAME opencode
  $CMD_NAME search --tag security
  $CMD_NAME search "FastAPI rate limit"

Legacy: \`brain\` is a symlink to \`synapse\` when installed via install.sh.
EOF
}

doctor() {
  local rc=0 path
  for path in "$BRAIN_BOOT" "$BRAIN_VAULT/index.md" "$BRAIN_VAULT/_meta/workflow.md" "$BRAIN_GLOBAL_AGENTS"; do
    if [[ -f "$path" ]]; then
      printf 'ok   %s\n' "$path"
    else
      printf 'miss %s\n' "$path"
      rc=1
    fi
  done
  return "$rc"
}

status() {
  if [[ "${BRAIN_LOADED:-0}" == "1" ]]; then
    printf 'synapse: ACTIVE in this environment\n'
  else
    printf 'synapse: NOT active — start via "%s <cli>" or a shell alias\n' "$CMD_NAME"
  fi
  printf 'vault:    %s\n' "$BRAIN_VAULT"
  printf 'skills:   %s\n' "$BRAIN_SKILLS_DIR"
  printf 'session:  %s\n' "$BRAIN_SESSION_ID"
  local now; now="$(vault_hash)"
  if [[ "${BRAIN_LOADED:-0}" == "1" && "$now" != "$BRAIN_VAULT_HASH" ]]; then
    printf 'hash:     %s  (STALE — vault changed since load; now %s)\n' "$BRAIN_VAULT_HASH" "$now"
  else
    printf 'hash:     %s\n' "$now"
  fi
  doctor
}

strip_rc_block() {
  local rc="$1" tmp
  tmp="$(mktemp)"
  awk '
    /# >>> Synapse >>>/ { skip=1 }
    skip && /# <<< Synapse <<</ { skip=0; next }
    /# >>> Agent Brain Runtime >>>/ { skip=1 }
    skip && /# <<< Agent Brain Runtime <<</ { skip=0; next }
    !skip { print }
  ' "$rc" > "$tmp" && mv "$tmp" "$rc"
}

reinit() {
  local prefix="$SELF_DIR" rc default_rc
  case "${SHELL:-}" in
    *bash) default_rc="$HOME/.bashrc" ;;
    *)     default_rc="$HOME/.zshrc" ;;
  esac
  rc="${SHELL_RC:-$default_rc}"

  if [[ -f "$rc" ]]; then
    strip_rc_block "$rc"
  fi

  cat >> "$rc" <<EOF

# >>> Synapse >>>
export SYNAPSE_HOME="$BRAIN_ROOT"
export BRAIN_ROOT="$BRAIN_ROOT"
# Vault is resolved dynamically by synapse so "synapse vault <name>" applies
# immediately. Export BRAIN_VAULT yourself only to pin a specific vault.
export OBSIDIAN_WIKI_REPO="\${OBSIDIAN_WIKI_REPO:-\$BRAIN_ROOT}"
export OBSIDIAN_LINK_FORMAT="\${OBSIDIAN_LINK_FORMAT:-wikilink}"
case ":\$PATH:" in
  *":$prefix:"*) ;;
  *) export PATH="$prefix:\$PATH" ;;
esac
alias codex='synapse codex'
alias opencode='synapse opencode'
alias claude='synapse claude'
alias gemini='synapse gemini'
# <<< Synapse <<<
EOF
  printf 'synapse: rewrote Synapse block in %s\n' "$rc"
  printf 'synapse: open a new terminal (or source it) to apply.\n'
}

check() {
  local v="$BRAIN_VAULT/_meta/validate.py" d="$BRAIN_VAULT/_meta/dedup.py" sk="$BRAIN_VAULT/_meta/skill.py" rc=0
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'synapse: python3 not found; cannot run check\n' >&2
    return 2
  fi
  if [[ -f "$v" ]]; then
    printf '== validate ==\n'
    python3 "$v" "$@" || rc=$?
  else
    printf 'synapse: no validate.py at %s\n' "$v" >&2
    rc=1
  fi
  if [[ -f "$d" ]]; then
    printf '\n== dedup (candidates) ==\n'
    python3 "$d" || true
  fi
  if [[ -f "$sk" ]]; then
    printf '\n== skill deps ==\n'
    BRAIN_SKILLS_DIR="$BRAIN_SKILLS_DIR" python3 "$sk" deps || rc=$?
  fi
  return "$rc"
}

# Locate the bundled templates dir (repo checkout, installed copy, or override).
resolve_templates() {
  if [[ -n "${SYNAPSE_TEMPLATES:-}" && -d "${SYNAPSE_TEMPLATES:-}" ]]; then
    printf '%s' "$SYNAPSE_TEMPLATES"; return
  fi
  if [[ -d "$SELF_DIR/../templates" ]]; then printf '%s' "$SELF_DIR/../templates"; return; fi
  if [[ -d "$BRAIN_ROOT/templates" ]]; then printf '%s' "$BRAIN_ROOT/templates"; return; fi
  printf ''
}

# Optional retrieval layer (file-based). Delegates to _meta/search.py.
search_cmd() {
  local s="$BRAIN_VAULT/_meta/search.py"
  if [[ ! -f "$s" ]]; then
    printf 'synapse: retrieval engine not found at %s\n' "$s" >&2
    return 2
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'synapse: python3 not found; cannot run search\n' >&2
    return 2
  fi
  exec python3 "$s" "$@"
}

# Ingest: register an immutable source under raw/ with provenance, then hand the
# agent the ingest recipe (read -> summary page -> revise wiki -> index -> log).
# This is Karpathy's first operation: raw in, derived wiki out — never edit raw.
ingest_cmd() {
  local src="${1:-}" title="${2:-}" raw_dir="$BRAIN_VAULT/raw" stamp slug dest raw_rel
  if [[ -z "$src" ]]; then
    printf 'usage: %s ingest <path-or-url> [title]\n\n' "$CMD_NAME"
    printf 'Records a source under raw/ (immutable), creates a linked sources/ page\n'
    printf '(frontmatter + index.md entry + log.md entry), then prints the ingest recipe.\n'
    printf 'URLs are recorded as a stub note pointing at the source.\n'
    return 2
  fi
  mkdir -p "$raw_dir"
  stamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  if [[ "$src" =~ ^https?:// ]]; then
    slug="$(printf '%s' "${title:-$src}" | tr '[:upper:] ' '[:lower:]-' | tr -cd 'a-z0-9-' | cut -c1-60)"
    [[ -n "$slug" ]] || slug="source-$(date -u +%s)"
    dest="$raw_dir/$slug.md"
    [[ -n "$title" ]] || title="$src"
    if [[ -e "$dest" ]]; then
      printf 'synapse: raw source already exists: %s (not overwriting)\n' "$dest" >&2
    else
      printf -- '---\nsource: %s\ningested: %s\nimmutable: true\n---\n\n# %s\n\nFetched from <%s>. Paste or attach the captured content below; do not edit after ingest.\n' \
        "$src" "$stamp" "$title" "$src" > "$dest"
      printf 'synapse: recorded source stub -> %s\n' "$dest"
    fi
    raw_rel="raw/$slug.md"
  elif [[ -f "$src" ]]; then
    dest="$raw_dir/$(basename "$src")"
    [[ -n "$title" ]] || title="$(basename "${src%.*}")"
    if [[ -e "$dest" ]]; then
      printf 'synapse: raw source already exists: %s (not overwriting)\n' "$dest" >&2
    else
      cp "$src" "$dest"
      printf 'synapse: copied source -> %s (immutable)\n' "$dest"
    fi
    raw_rel="raw/$(basename "$src")"
  else
    printf 'synapse: not a file or URL: %s\n' "$src" >&2
    return 2
  fi

  # Create the derived sources/ page (frontmatter + index + log) deterministically,
  # so the agent only has to fill the body — ingest is a real wiki mutation, not a memo.
  local w="$BRAIN_VAULT/_meta/wiki.py" page=""
  if [[ -f "$w" ]] && command -v python3 >/dev/null 2>&1; then
    page="$(python3 "$w" new --category sources --title "$title" \
              --source "$raw_rel" --op INGEST 2>&1)" || true
    if [[ -f "$BRAIN_VAULT/$page" ]]; then
      printf 'synapse: created %s (cites %s; cataloged in index.md, logged)\n' "$page" "$raw_rel"
    else
      printf 'synapse: %s\n' "$page" >&2
    fi
  fi

  cat <<EOF

ingest recipe (see _meta/workflow.md → Ingest):
  1. Read $raw_rel (immutable source).
  2. Fill the Takeaways in ${page:-the sources/ page} — the high-signal distillation.
  3. Revise affected wiki pages (concepts/, techniques/, projects/, analysis/, ...)
     and cross-link them with [[wikilinks]].
  4. synapse lint  (health-check the result — 0 errors).
EOF
}

# File a piece of knowledge back as a wiki page (frontmatter + index + log). The
# compounding half of query: a good answer becomes a durable page, not a one-off reply.
file_cmd() {
  local w="$BRAIN_VAULT/_meta/wiki.py"
  if [[ "${1:-}" == "" || "${2:-}" == "" ]]; then
    printf 'usage: %s file <category> <title> [--summary S] [--tags a,b] [--source SRC] [--link PAGE]\n' "$CMD_NAME"
    printf 'categories: concepts people organizations techniques sources analysis skills projects journal\n'
    return 2
  fi
  if [[ ! -f "$w" ]]; then
    printf 'synapse: wiki engine not found at %s\n' "$w" >&2
    return 2
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'synapse: python3 not found; cannot file a page\n' >&2
    return 2
  fi
  local category="$1" title="$2"; shift 2
  local page
  page="$(python3 "$w" new --category "$category" --title "$title" --op FILE "$@")" || return $?
  if [[ -f "$BRAIN_VAULT/$page" ]]; then
    printf 'synapse: filed %s (cataloged in index.md, logged)\n' "$page"
  else
    printf '%s\n' "$page"
  fi
}

# Wire the continuous-loop hooks into Claude Code settings (SessionStart / UserPromptSubmit
# / Stop), pointed at the active vault. Safe JSON merge: idempotent, backs up, replaces
# only Synapse-owned entries (those under _meta/hooks/). `print` emits the snippet instead.
hooks_cmd() {
  local action="${1:-install}" settings="${2:-$HOME/.claude/settings.json}"
  local hooks_dir="$BRAIN_VAULT/_meta/hooks"
  if [[ ! -d "$hooks_dir" ]]; then
    printf 'synapse: hooks not found at %s (is the vault initialized?)\n' "$hooks_dir" >&2
    return 2
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'synapse: python3 not found; cannot manage hooks\n' >&2
    return 2
  fi
  HOOKS_DIR="$hooks_dir" SETTINGS="$settings" ACTION="$action" python3 - <<'PY'
import json, os, shutil, sys

hooks_dir = os.environ["HOOKS_DIR"]
settings  = os.environ["SETTINGS"]
action    = os.environ["ACTION"]

mapping = {
    "SessionStart":     os.path.join(hooks_dir, "session-enforce.sh"),
    "UserPromptSubmit": os.path.join(hooks_dir, "prompt-retrieve.sh"),
    "Stop":             os.path.join(hooks_dir, "stop-check.sh"),
}

def entry(cmd):
    return {"hooks": [{"type": "command", "command": cmd}]}

if action == "print":
    print(json.dumps({"hooks": {e: [entry(c)] for e, c in mapping.items()}}, indent=2))
    sys.exit(0)

if action != "install":
    print(f"synapse: unknown hooks action '{action}' (install|print)", file=sys.stderr)
    sys.exit(2)

data = {}
if os.path.isfile(settings):
    try:
        data = json.load(open(settings, encoding="utf-8"))
    except Exception as exc:
        print(f"synapse: cannot parse {settings}: {exc}", file=sys.stderr)
        sys.exit(2)
    shutil.copy(settings, settings + ".bak")

hooks = data.setdefault("hooks", {})
for event, cmd in mapping.items():
    groups = hooks.setdefault(event, [])
    # drop any prior Synapse-owned command (same script basename under _meta/hooks)
    base = os.path.basename(cmd)
    kept = []
    for g in groups:
        inner = [h for h in g.get("hooks", [])
                 if not (h.get("command", "").endswith(base) and "_meta/hooks" in h.get("command", ""))]
        if inner:
            g["hooks"] = inner
            kept.append(g)
        elif not g.get("hooks"):
            kept.append(g)  # preserve unrelated empty/other-keyed groups
    kept = [g for g in kept if g.get("hooks")]
    kept.append(entry(cmd))
    hooks[event] = kept

os.makedirs(os.path.dirname(settings) or ".", exist_ok=True)
with open(settings, "w", encoding="utf-8") as fh:
    json.dump(data, fh, indent=2)
    fh.write("\n")
print(f"synapse: wired SessionStart / UserPromptSubmit / Stop hooks into {settings}")
print(f"         (backup at {settings}.bak)" if os.path.isfile(settings + ".bak") else "")
print("         restart Claude Code (or open a new session) to load them.")
PY
}

# Install the right agent context file for a target tool, pointed at the vault.
setup_cmd() {
  local target="${1:-}" dest_dir="${2:-$PWD}" templates
  templates="$(resolve_templates)"

  if [[ -z "$target" ]]; then
    printf 'usage: %s setup <target> [dir]\n\n' "$CMD_NAME"
    printf 'targets: claude-code  codex  cursor  gemini  opencode\n'
    printf 'installs the matching context file into [dir] (default: current dir),\n'
    printf 'pointed at the active vault: %s\n' "$BRAIN_VAULT"
    return 0
  fi
  if [[ -z "$templates" ]]; then
    printf 'synapse: templates not found (set SYNAPSE_TEMPLATES to the templates dir)\n' >&2
    return 2
  fi

  local src name
  case "$target" in
    claude|claude-code)     src="$templates/CLAUDE.md";  name="CLAUDE.md" ;;
    codex|opencode|cursor)  src="$templates/AGENTS.md";  name="AGENTS.md" ;;
    gemini)                 src="$templates/GEMINI.md";  name="GEMINI.md" ;;
    *)
      printf 'synapse: unknown target: %s (claude-code|codex|cursor|gemini|opencode)\n' "$target" >&2
      return 2 ;;
  esac
  if [[ ! -f "$src" ]]; then
    printf 'synapse: template missing: %s\n' "$src" >&2
    return 2
  fi

  mkdir -p "$dest_dir"
  local dst="$dest_dir/$name"
  if [[ -f "$dst" ]] && cmp -s "$src" "$dst"; then
    printf 'synapse: %s already up to date (%s)\n' "$name" "$dst"
  elif [[ -f "$dst" ]]; then
    printf 'synapse: %s exists and differs — left unchanged: %s\n' "$name" "$dst" >&2
    printf '         remove it (or pass a clean dir) to reinstall the template.\n' >&2
  else
    cp "$src" "$dst"
    printf 'synapse: installed %s -> %s\n' "$name" "$dst"
  fi

  if [[ "$target" == claude* ]]; then
    local hooks="$BRAIN_VAULT/_meta/hooks"
    if [[ -d "$hooks" ]]; then
      printf 'hooks: %s/{session-enforce.sh,prompt-retrieve.sh,stop-check.sh}\n' "$hooks"
      printf '       run "%s hooks install" to wire the continuous loop (per-turn retrieval\n' "$CMD_NAME"
      printf '       + distill-on-close) into ~/.claude/settings.json. See README.\n'
    fi
  fi
  printf 'vault: %s\n' "$BRAIN_VAULT"
}

which_cmd() {
  local c="${1:-}" p
  if [[ -z "$c" ]]; then
    printf 'usage: %s which <cmd>\n' "$CMD_NAME" >&2
    return 2
  fi
  p="$(command -v -- "$c" 2>/dev/null)" || { printf 'synapse: command not found: %s\n' "$c" >&2; return 127; }
  printf 'command:  %s\n' "$c"
  printf 'resolves: %s\n' "$p"
  if grep -qsE "$SELF_DIR/(synapse|brain)" "$p" 2>/dev/null; then
    printf 'type:     synapse wrapper -> %s\n' "$SELF_DIR"
  else
    printf 'type:     direct binary (not wrapped by synapse)\n'
  fi
  if [[ -e "$SELF_DIR/.synapse-real/$c" ]]; then
    printf 'real:     %s\n' "$(readlink "$SELF_DIR/.synapse-real/$c" 2>/dev/null || echo "$SELF_DIR/.synapse-real/$c")"
  fi
}

# Seed a new named vault: inherit the engine + workflow from an existing vault,
# but start with an empty knowledge surface.
scaffold_vault() {
  local target="$1" seed=""
  if [[ -d "$BRAIN_VAULT/_meta" ]]; then seed="$BRAIN_VAULT"
  elif [[ -d "$BRAIN_ROOT/vault/_meta" ]]; then seed="$BRAIN_ROOT/vault"; fi

  # Karpathy LLM Wiki layout: immutable raw/ sources + the LLM-owned wiki. Scaffold the
  # core categories a coding vault uses constantly (concepts/techniques/projects/skills)
  # plus sources/ (ingest target); optional ones (people/organizations/analysis/journal,
  # see _meta/categories) are created on demand when first filed into.
  mkdir -p \
    "$target/_meta/hooks" "$target/raw" "$target/sources" \
    "$target/concepts" "$target/techniques" "$target/projects" "$target/skills"

  if [[ -n "$seed" ]]; then
    cp -R "$seed/_meta/." "$target/_meta/" 2>/dev/null || true
    [[ -f "$seed/AGENTS.md" ]] && cp "$seed/AGENTS.md" "$target/AGENTS.md"
  fi
  # shellcheck disable=SC2016  # backticks are literal Markdown, not a command substitution
  [[ -f "$target/raw/README.md" ]] || printf '# raw/ — immutable sources\n\nDrop original sources here (or let `synapse ingest` copy them in). The wiki is\nderived from these; never edit raw files in place — supersede them with a new source.\n' > "$target/raw/README.md"
  # shellcheck disable=SC2016  # backticks are literal Markdown, not a command substitution
  [[ -f "$target/index.md" ]]  || printf '# Index\n\n_Empty vault. Ingest a source (`synapse ingest <path>`), then distill it into concepts/, techniques/, projects/, skills/ (see `_meta/categories` for the full, configurable set)._\n' > "$target/index.md"
  [[ -f "$target/hot.md" ]]    || printf '# Hot\n\n_Most-used notes surface here._\n' > "$target/hot.md"
  [[ -f "$target/log.md" ]]    || printf '# Log\n' > "$target/log.md"
  # shellcheck disable=SC2016  # backticks are literal Markdown, not a command substitution
  [[ -f "$target/AGENTS.md" ]] || printf '# Vault operations\n\nSee `_meta/workflow.md`.\n' > "$target/AGENTS.md"
}

vault_cmd() {
  local name="${1:-}" active=""
  [[ -f "$ACTIVE_VAULT_FILE" ]] && active="$(tr -d '[:space:]' < "$ACTIVE_VAULT_FILE" 2>/dev/null)"

  if [[ -z "$name" ]]; then
    if [[ -n "$active" && -d "$VAULTS_DIR/$active" ]]; then
      printf 'active vault: %s  (%s)\n' "$active" "$VAULTS_DIR/$active"
    else
      printf 'active vault: default  (%s)\n' "$BRAIN_ROOT/vault"
    fi
    printf 'vaults dir:   %s\n\n' "$VAULTS_DIR"
    if compgen -G "$VAULTS_DIR/*/" >/dev/null 2>&1; then
      printf 'named vaults:\n'
      local d n
      for d in "$VAULTS_DIR"/*/; do
        n="$(basename "$d")"
        if [[ "$n" == "$active" ]]; then printf '  * %s\n' "$n"; else printf '    %s\n' "$n"; fi
      done
    else
      printf 'no named vaults yet — create/switch with: %s vault <name>\n' "$CMD_NAME"
    fi
    if [[ -n "$ENV_BRAIN_VAULT" ]]; then
      printf '\nnote: BRAIN_VAULT is pinned in your environment (%s);\n' "$ENV_BRAIN_VAULT"
      printf '      switching has no effect until you unset it or run "%s reinit".\n' "$CMD_NAME"
      return 0
    fi
    return 0
  fi

  mkdir -p "$BRAIN_ROOT"
  case "$name" in
    default|legacy)
      rm -f "$ACTIVE_VAULT_FILE"
      printf 'synapse: active vault -> default (%s)\n' "$BRAIN_ROOT/vault"
      ;;
    */*|.*)
      printf 'synapse: invalid vault name: %s\n' "$name" >&2
      return 2
      ;;
    *)
      local target="$VAULTS_DIR/$name"
      if [[ ! -d "$target" ]]; then
        printf 'synapse: creating new vault "%s"\n' "$name"
        scaffold_vault "$target"
      fi
      printf '%s\n' "$name" > "$ACTIVE_VAULT_FILE"
      printf 'synapse: active vault -> %s (%s)\n' "$name" "$target"
      ;;
  esac

  if [[ -n "$ENV_BRAIN_VAULT" ]]; then
    printf 'note: BRAIN_VAULT is pinned in your environment; run "%s reinit" and open a new shell to apply.\n' "$CMD_NAME" >&2
    return 0
  fi
}

case "${1:-}" in
  ""|-h|--help)
    usage
    exit 0
    ;;
  vault)
    vault_cmd "${2:-}"
    exit $?
    ;;
  status)
    status
    exit 0
    ;;
  check|lint)
    shift
    check "$@"
    exit $?
    ;;
  ingest)
    ingest_cmd "${2:-}" "${3:-}"
    exit $?
    ;;
  file)
    shift
    file_cmd "$@"
    exit $?
    ;;
  hooks)
    hooks_cmd "${2:-install}" "${3:-$HOME/.claude/settings.json}"
    exit $?
    ;;
  metrics|stats)
    shift
    m="$BRAIN_VAULT/_meta/metrics.py"
    if [[ ! -f "$m" ]]; then
      printf 'synapse: metrics engine not found at %s\n' "$m" >&2
      exit 2
    fi
    if ! command -v python3 >/dev/null 2>&1; then
      printf 'synapse: python3 not found; cannot run metrics\n' >&2
      exit 2
    fi
    exec python3 "$m" "$@"
    ;;
  query|index|digest)
    if [[ "$1" == "digest" && -z "${2:-}" ]]; then
      search_cmd digest --write
    else
      search_cmd "$@"
    fi
    ;;
  setup)
    setup_cmd "${2:-}" "${3:-$PWD}"
    exit $?
    ;;
  search)
    shift
    # Delegate to the weighted, frontmatter-aware retriever (search.py), scanning
    # bodies by default; --tag/--title/--exact still work as documented.
    search_cmd search --body "$@"
    exit $?
    ;;
  skill)
    shift
    s="$BRAIN_VAULT/_meta/skill.py"
    if [[ ! -f "$s" ]]; then
      printf 'synapse: skill engine not found at %s\n' "$s" >&2
      exit 2
    fi
    if ! command -v python3 >/dev/null 2>&1; then
      printf 'synapse: python3 not found; cannot run skill\n' >&2
      exit 2
    fi
    BRAIN_SKILLS_DIR="$BRAIN_SKILLS_DIR" exec python3 "$s" "$@"
    ;;
  reinit)
    reinit
    exit 0
    ;;
  doctor)
    doctor
    exit $?
    ;;
  which)
    which_cmd "${2:-}"
    exit $?
    ;;
  env)
    printf 'SYNAPSE_HOME=%s\n' "$SYNAPSE_HOME"
    printf 'BRAIN_ROOT=%s\n' "$BRAIN_ROOT"
    printf 'BRAIN_VAULT=%s\n' "$BRAIN_VAULT"
    printf 'BRAIN_BOOT=%s\n' "$BRAIN_BOOT"
    printf 'BRAIN_WORKFLOW=%s\n' "$BRAIN_WORKFLOW"
    printf 'BRAIN_GLOBAL_AGENTS=%s\n' "$BRAIN_GLOBAL_AGENTS"
    printf 'BRAIN_SKILLS_DIR=%s\n' "$BRAIN_SKILLS_DIR"
    printf 'BRAIN_SESSION_ID=%s\n' "$BRAIN_SESSION_ID"
    printf 'BRAIN_VAULT_HASH=%s\n' "$BRAIN_VAULT_HASH"
    printf 'BRAIN_LOADED=%s\n' "${BRAIN_LOADED:-0}"
    printf 'OBSIDIAN_VAULT_PATH=%s\n' "$OBSIDIAN_VAULT_PATH"
    printf 'OBSIDIAN_WIKI_REPO=%s\n' "$OBSIDIAN_WIKI_REPO"
    printf 'OBSIDIAN_LINK_FORMAT=%s\n' "$OBSIDIAN_LINK_FORMAT"
    exit 0
    ;;
esac

cmd="$1"
shift

if ! command -v -- "$cmd" >/dev/null 2>&1; then
  printf 'synapse: command not found: %s\n' "$cmd" >&2
  exit 127
fi

if [[ "${BRAIN_LOADED:-0}" != "1" && "${BRAIN_QUIET:-0}" != "1" ]]; then
  printf 'synapse[vault]: %s (session: %s)\n' "$BRAIN_VAULT" "$BRAIN_SESSION_ID" >&2
fi

export BRAIN_LOADED=1

exec "$cmd" "$@"
